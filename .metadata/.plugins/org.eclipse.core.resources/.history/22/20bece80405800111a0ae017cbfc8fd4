	public void sortByAge() {
		
		//Sort is a class with static method by. By takes arguments as varibale name in Entity class
		// By can also take multiple arguments.First it sorts by age and if age is same then it sorts by id.
		
		
		Sort sort = Sort.by("age" , "id").descending(); 
		
		List<UserInfo> allUsers = userRepo.findAll(sort); 
		allUsers.forEach(System.out::println);
	}
	
	public void pagination() {
		
	int pageNumber = 4;  // this data comes from UI
	int pageSize = 10;
	
	PageRequest pageReq = PageRequest.of(pageNumber, pageSize);
	Page<UserInfo> allUsers = userRepo.findAll(pageReq); 
	List<UserInfo> listOfUsersInPage = allUsers.getContent();
	
	listOfUsersInPage.forEach(System.out::println);
		
		
	}
	
	
